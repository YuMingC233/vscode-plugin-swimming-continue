{
  "name": "vscode-plugin-swimming",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.1.2",
  "publisher": "swimming",
  "icon": "128.png",
  "engines": {
    "node": ">=20.0.0",
    "vscode": "^1.100.0"
  },
  "packageManager": "pnpm@10.32.1",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:extension.swimming.rewriteCode",
    "onCommand:extension.swimming.shadowRewriteCode",
    "onCommand:extension.swimming.closeWriteCode",
    "onCommand:extension.swimming.pauseWriteCode",
    "onCommand:extension.swimming.switchWriteMode",
    "onCommand:extension.swimming.exitShadowRewrite",
    "onCommand:extension.swimming.selectLookWhileTypingTarget",
    "onCommand:extension.swimming.clearLookWhileTypingTarget",
    "onCommand:extension.swimming.scrollLookWhileTypingUp",
    "onCommand:extension.swimming.scrollLookWhileTypingDown",
    "onCommand:extension.swimming.closeLookWhileTypingTarget"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "extension.swimming.rewriteCode",
        "title": "%command.rewriteCode%"
      },
      {
        "command": "extension.swimming.closeWriteCode",
        "title": "%command.closeWriteCode%"
      },
      {
        "command": "extension.swimming.shadowRewriteCode",
        "title": "%command.shadowRewriteCode%"
      },
      {
        "command": "extension.swimming.pauseWriteCode",
        "title": "%command.pauseWriteCode%"
      },
      {
        "command": "extension.swimming.switchWriteMode",
        "title": "%command.switchWriteMode%"
      },
      {
        "command": "extension.swimming.exitShadowRewrite",
        "title": "%command.exitShadowRewrite%"
      },
      {
        "command": "extension.swimming.selectLookWhileTypingTarget",
        "title": "%command.selectLookWhileTypingTarget%"
      },
      {
        "command": "extension.swimming.clearLookWhileTypingTarget",
        "title": "%command.clearLookWhileTypingTarget%"
      },
      {
        "command": "extension.swimming.scrollLookWhileTypingUp",
        "title": "%command.scrollLookWhileTypingUp%"
      },
      {
        "command": "extension.swimming.scrollLookWhileTypingDown",
        "title": "%command.scrollLookWhileTypingDown%"
      },
      {
        "command": "extension.swimming.closeLookWhileTypingTarget",
        "title": "%command.closeLookWhileTypingTarget%"
      }
    ],
    "submenus": [
      {
        "id": "swimming.menu",
        "label": "%submenu.swimming%"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "swimming.menu",
          "group": "navigation"
        }
      ],
      "swimming.menu": [
        {
          "command": "extension.swimming.rewriteCode",
          "when": "editorFocus",
          "group": "1_rewrite"
        },
        {
          "command": "extension.swimming.shadowRewriteCode",
          "when": "editorFocus",
          "group": "2_shadow"
        },
        {
          "command": "extension.swimming.pauseWriteCode",
          "when": "editorFocus",
          "group": "3_rewriteControls"
        },
        {
          "command": "extension.swimming.switchWriteMode",
          "when": "editorFocus",
          "group": "3_rewriteControls"
        },
        {
          "command": "extension.swimming.exitShadowRewrite",
          "when": "editorFocus && vscodePluginSwimming.shadowActive",
          "group": "3_rewriteControls"
        },
        {
          "command": "extension.swimming.closeWriteCode",
          "when": "editorFocus",
          "group": "3_rewriteControls"
        },
        {
          "command": "extension.swimming.selectLookWhileTypingTarget",
          "when": "editorFocus",
          "group": "4_lookWhileTyping"
        },
        {
          "command": "extension.swimming.clearLookWhileTypingTarget",
          "when": "editorFocus && vscodePluginSwimming.lookWhileTypingTargetVisible",
          "group": "4_lookWhileTyping"
        },
        {
          "command": "extension.swimming.scrollLookWhileTypingUp",
          "when": "editorFocus && vscodePluginSwimming.lookWhileTypingTargetVisible",
          "group": "4_lookWhileTyping"
        },
        {
          "command": "extension.swimming.scrollLookWhileTypingDown",
          "when": "editorFocus && vscodePluginSwimming.lookWhileTypingTargetVisible",
          "group": "4_lookWhileTyping"
        },
        {
          "command": "extension.swimming.closeLookWhileTypingTarget",
          "when": "editorFocus && vscodePluginSwimming.lookWhileTypingTargetVisible",
          "group": "4_lookWhileTyping"
        }
      ]
    },
    "keybindings": [
      {
        "command": "extension.swimming.closeWriteCode",
        "key": "ctrl+alt+x",
        "mac": "alt+cmd+x"
      },
      {
        "command": "extension.swimming.pauseWriteCode",
        "key": "ctrl+alt+shift+p",
        "mac": "alt+cmd+shift+p"
      },
      {
        "command": "extension.swimming.exitShadowRewrite",
        "key": "escape",
        "when": "editorTextFocus && vscodePluginSwimming.shadowActive"
      },
      {
        "command": "extension.swimming.shadowDeleteLeft",
        "key": "backspace",
        "when": "editorTextFocus && vscodePluginSwimming.shadowActive"
      },
      {
        "command": "extension.swimming.shadowEnter",
        "key": "enter",
        "when": "editorTextFocus && vscodePluginSwimming.shadowActive"
      },
      {
        "command": "extension.swimming.shadowTab",
        "key": "tab",
        "when": "editorTextFocus && vscodePluginSwimming.shadowActive"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%configuration.title%",
      "properties": {
        "vscodePluginSwimming.reWriteSpeed": {
          "type": "number",
          "default": 200,
          "description": "%configuration.rewriteSpeed%"
        },
        "vscodePluginSwimming.rewriteMode": {
          "type": "string",
          "default": "once",
          "description": "%configuration.rewriteMode%"
        },
        "vscodePluginSwimming.shadowRequireShiftForSymbols": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shadowRequireShiftForSymbols%"
        },
        "vscodePluginSwimming.shadowShowInlineSuggestion": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shadowShowInlineSuggestion%"
        },
        "vscodePluginSwimming.shadowRequireManualLineBreaksAndIndentation": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.shadowRequireManualLineBreaksAndIndentation%"
        },
        "vscodePluginSwimming.lookWhileTypingStepLines": {
          "type": "number",
          "minimum": 1,
          "default": 3,
          "description": "%configuration.lookWhileTypingStepLines%"
        },
        "vscodePluginSwimming.lookWhileTypingScrollUpKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1,
          "default": "-",
          "description": "%configuration.lookWhileTypingScrollUpKey%"
        },
        "vscodePluginSwimming.lookWhileTypingScrollDownKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1,
          "default": "=",
          "description": "%configuration.lookWhileTypingScrollDownKey%"
        },
        "vscodePluginSwimming.lookWhileTypingCloseTargetKey": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1,
          "default": "\\",
          "description": "%configuration.lookWhileTypingCloseTargetKey%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "test": "pnpm run compile && node --test test/*.test.js",
    "watch": "tsc -watch -p ./",
    "vsce:publish": "pnpm exec vsce package && pnpm exec vsce publish"
  },
  "repository": {
    "url": "https://github.com/zy445566/vscode-plugin-swimming"
  },
  "keywords": [
    "swimming",
    "vscode",
    "摸鱼",
    "划水",
    "模拟代码"
  ],
  "author": "zy445566",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zy445566/vscode-plugin-swimming/issues"
  },
  "homepage": "https://github.com/zy445566/vscode-plugin-swimming#readme",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.8.2"
  }
}
